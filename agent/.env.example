# ── Supabase ──────────────────────────────────────────────────────────────────
# Same project as your Artisanal Brew web app
VITE_SUPABASE_URL=https://your-project.supabase.co

# Service role key bypasses Row Level Security — use this for the agent.
# Dashboard → Settings → API → service_role (secret)
# NEVER expose this key in the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Fallback: if you only have the anon key, the agent will use it instead.
# Note: anon key requires RLS policies that allow the AGENT_USER_ID to read/write.
# VITE_SUPABASE_KEY=your_supabase_anon_key

# ── Agent identity ─────────────────────────────────────────────────────────────
# UUID of the Supabase auth user the agent acts as.
# Create a dedicated user in the Supabase dashboard (Auth → Users → Add user)
# and paste the UUID here.
AGENT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Gemini AI (optional) ───────────────────────────────────────────────────────
# If set, the agent uses Gemini to write personalised brew notes and purchase
# reasons. If unset, rule-based fallbacks are used instead.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
