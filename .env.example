# Supabase — https://supabase.com/dashboard → Settings → API
# VITE_ prefix makes these available in the browser bundle
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_publishable_key

# Google Gemini (free) — https://aistudio.google.com/app/apikey
# NO VITE_ prefix — server-side only, read by Vercel serverless functions
# Never expose this key in the browser
GEMINI_API_KEY=your_gemini_api_key
